# Supabase (officiant applications + couple auth/profiles)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Couple Google sign-in: enable Google in Authentication → Providers, then add every
# OAuth redirect URL your app uses (Expo dev: exp://… and Linking.createURL output,
# production: https://your-domain/..., native: carriageapp://sign-in) under
# Authentication → URL configuration → Redirect URLs. Apply
# supabase/migrations/* including couple_profiles for quiz_completed RLS.
