# Supabase (officiant applications + couple auth/profiles)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Web OAuth: canonical production host (no trailing slash). Vercel/preview: set to that deploy URL
# so PKCE return matches the tab origin. Supabase must allow https://www.carriage.app/sign-in (and
# http://localhost:PORT/sign-in for local dev). Native: carriageapp://… from Linking.
EXPO_PUBLIC_SITE_URL=https://www.carriage.app

# Couple Google sign-in: enable Google in Authentication → Providers. Google Cloud redirect URI is
# only https://<ref>.supabase.co/auth/v1/callback. Apply supabase/migrations for couple_profiles RLS.
